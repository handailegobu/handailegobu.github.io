  <div class="row">
    <div class="6u 12u(mobile)">
      <section class="box">
        <a href="/gallery/member_kuruponkyu/ramen/"><img width="480" src="/images/gallery/member_kuruponkyu/ramen2.jpg" /></a>
        <br />
        <a href="/gallery/member_kuruponkyu/ramen/">↑クリックして作品解説を見る↑</a>
      </section>
    </div>
    <div class="6u 12u(mobile)">
      <h3>ラーメン</h3>
    </div>
  </div>
</BaseLayout>
