---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  /** <title> に入る完全なタイトル文字列（旧サイトの命名を踏襲） */
  title: string;
  /** meta description / OGP description。未指定時はサイト既定 */
  description?: string;
  /** OGP画像の絶対パス（例: /images/top/shabani.jpg）。未指定時はロゴ */
  ogImage?: string;
  /** <body> のクラス（homepage / left-sidebar / no-sidebar 等、旧サイト互換） */
  bodyClass?: string;
}

const {
  title,
  description = '大阪大学レゴ部（Osaka University LEGO® User Group）の公式サイト。作品集・活動紹介・入部案内・お問い合わせ。',
  ogImage = '/images/logo.png',
  bodyClass = 'no-sidebar',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="ja">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EXMSWLBNQG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-EXMSWLBNQG');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/images/logo.png" />

    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="大阪大学レゴ部" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/nav.css" />
    <!-- アイコン（Font Awesome kit）。将来は自己ホスト化を検討 -->
    <script is:inline src="https://kit.fontawesome.com/652f16b4e9.js" crossorigin="anonymous"></script>
  </head>
  <body class={bodyClass}>
    <div id="page-wrapper">
      <!-- Header -->
      <div id="header-wrapper">
        <div id="header">
          <div id="topHeader">
            <Nav />
          </div>
          <!-- トップページのバナー/イントロ等はここに差し込む -->
          <slot name="header" />
        </div>
      </div>

      <!-- Main -->
      <div id="main-wrapper">
        <div class="container">
          <slot />
        </div>
      </div>

      <!-- Footer -->
      <Footer />
    </div>

    <!-- ナビ挙動（ドロップダウン/モバイル）。jQuery/Skel非依存の素のJS -->
    <script is:inline src="/javascript/nav.js" defer></script>
  </body>
</html>
