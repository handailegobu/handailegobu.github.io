---
// ナビゲーション。現在地（パス）に応じて該当項目へ .current を付与する。
// 旧実装の currentPos（main.js）の置き換え。
const pathname = Astro.url.pathname;

function isCurrent(section: string): boolean {
  if (section === 'home') return pathname === '/' || pathname === '';
  return pathname === `/${section}` || pathname.startsWith(`/${section}/`);
}
---

<!-- Logo -->
<h1><a href="/"><img src="/images/logo.png" alt="大阪大学レゴ部" /></a></h1>

<!-- Nav -->
<nav id="nav">
  <ul>
    <li class={isCurrent('home') ? 'current' : undefined}>
      <a href="/">ホーム</a>
    </li>
    <li class={isCurrent('about') ? 'current' : undefined}>
      <a href="/about/">活動紹介</a>
      <ul>
        <li><a href="/about/#about">レゴ部とは？</a></li>
        <li><a href="/about/#workshop">過去の製作依頼</a></li>
        <li><a href="/about/#member">部員紹介</a></li>
      </ul>
    </li>
    <li class={isCurrent('gallery') ? 'current' : undefined}>
      <a href="/gallery/">作品集</a>
    </li>
    <li class={isCurrent('join') ? 'current' : undefined}>
      <a href="/join/">入部について</a>
    </li>
    <li class={isCurrent('contact') ? 'current' : undefined}>
      <a href="/contact/">お問い合わせ</a>
    </li>
  </ul>
</nav>
